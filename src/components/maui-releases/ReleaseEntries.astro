---
import {
  getAuthorDisplayName,
  getAuthorImageSrc,
  getInternalContributorProfileHref,
} from '../../data/authors';
import { formatLongDateUS } from '../../utils/date';
import PrimaryLinkButton from '../PrimaryLinkButton.astro';
import type { MauiReleaseEntry } from '../../data/releases';

interface Props {
  entries: MauiReleaseEntry[];
}

const { entries } = Astro.props;

function getContributorHref(username: string): string {
  const internal = getInternalContributorProfileHref(username);
  return internal ?? `/repo-contributors/maui/?q=${encodeURIComponent(username)}`;
}

function getContributorDisplayName(username: string): string {
  return getAuthorDisplayName(username);
}
---

<ul class="space-y-8" aria-label="MAUI release feed">
  {entries.map((entry) => {
    const detailUrl = `/maui-releases/${entry.id}/`;
    const contributorPreview = entry.data.contributors.slice(0, 8);
    return (
      <li class="border-b border-edge/30 pb-8 last:border-0 hover-glow rounded-xl px-4 py-6 -mx-4">
        <div class="flex flex-col gap-3 min-w-0">
          <a
            href={detailUrl}
            class="text-brand-dark text-xl font-header font-bold hover:text-brand transition-colors"
          >
            {entry.data.title}
          </a>
          <p class="text-muted-light text-sm flex flex-wrap items-center gap-x-2 gap-y-1">
            <time datetime={entry.data.date.toISOString()}>
              {formatLongDateUS(entry.data.date)}
            </time>
            {entry.data.prerelease && (
              <span class="rounded bg-brand-extra/20 px-1.5 py-0.5 text-xs font-semibold text-brand-extra">
                Preview
              </span>
            )}
          </p>
          {contributorPreview.length > 0 && (
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-[11px] font-semibold uppercase tracking-wide text-muted-light">
                Contributors
              </span>
              <div class="flex flex-wrap gap-1.5">
                {contributorPreview.map((username) => {
                  const href = getContributorHref(username);
                  const isInternal = href.startsWith('/');
                  return (
                    <a
                      href={href}
                      class="inline-flex items-center gap-1.5 rounded-full border border-edge/30 px-2.5 py-1 text-sm text-brand-dark transition hover:border-brand/40 hover:text-brand"
                      aria-label={`View ${getContributorDisplayName(username)}'s profile`}
                      target={isInternal ? undefined : '_blank'}
                      rel={isInternal ? undefined : 'noopener noreferrer'}
                    >
                      <img
                        src={getAuthorImageSrc(username, 64)}
                        alt=""
                        width="24"
                        height="24"
                        class="h-6 w-6 rounded-full"
                        loading="lazy"
                      />
                      <span>{getContributorDisplayName(username)}</span>
                    </a>
                  );
                })}
                {entry.data.contributors.length > 8 && (
                  <span class="text-sm text-muted-light">
                    +{entry.data.contributors.length - 8} more
                  </span>
                )}
              </div>
            </div>
          )}
          <PrimaryLinkButton href={detailUrl}>View release</PrimaryLinkButton>
        </div>
      </li>
    );
  })}
</ul>
